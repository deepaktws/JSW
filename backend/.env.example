# Copy to .env and adjust for local development.
#
# Postgres must be running before `npm run dev`. From backend/, run each line separately
# (do not paste several commands on one line — zsh can error on `#` / `@` in comments):
#   npm run db:all
# Or: npm run db:postgres  then  npm run db:setup
# After installing Docker Desktop: open the app, wait until it is "running", then use a new terminal so `docker` is on your PATH.
#
# If you see "Can't reach database server at localhost:5432", Postgres is not running.
DATABASE_URL="postgresql://app:app@localhost:5432/appdb?schema=public"
# Use 5050 locally on macOS — port 5000 is often used by AirPlay Receiver.
PORT=5050
NODE_ENV=development
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN=7d
# Local Node (not in Docker): FastAPI on host
FASTAPI_URL=http://127.0.0.1:8000
# Docker Compose: FASTAPI_URL is set in docker-compose.yml on the `server` service (http://excel-ml:8000). Python service lives in `../excel-ml/`, not under `backend/`.
FASTAPI_TIMEOUT_MS=120000
