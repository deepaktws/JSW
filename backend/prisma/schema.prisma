generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  name      String?
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  isActive  Boolean   @default(true)

  createdBy String    @default("00000000-0000-0000-0000-000000000000") @db.Uuid
  updatedBy String    @default("00000000-0000-0000-0000-000000000000") @db.Uuid
  deletedBy String?   @db.Uuid
}
